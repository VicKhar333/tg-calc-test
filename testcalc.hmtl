<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>Калькулятор стоимости</title>

<style>

body{
font-family: Arial;
background:#f5f5f5;
padding:20px;
}

.card{
background:white;
padding:20px;
border-radius:10px;
box-shadow:0 4px 10px rgba(0,0,0,0.1);
max-width:400px;
margin:auto;
}

h2{
text-align:center;
}

input{
width:100%;
padding:12px;
margin-top:10px;
border-radius:6px;
border:1px solid #ccc;
font-size:16px;
}

button{
width:100%;
padding:12px;
margin-top:15px;
background:#2AABEE;
color:white;
border:none;
border-radius:6px;
font-size:16px;
cursor:pointer;
}

button:hover{
background:#229ED9;
}

#result{
margin-top:15px;
font-size:18px;
font-weight:bold;
text-align:center;
}

</style>
</head>

<body>

<div class="card">

<h2>Расчет стоимости</h2>

<input id="area" type="number" placeholder="Введите площадь">

<input id="price" type="number" placeholder="Введите цену за м²">

<button onclick="calc()">Рассчитать</button>

<div id="result"></div>

</div>

<script>

function calc(){

let area = document.getElementById("area").value;
let price = document.getElementById("price").value;

if(area === "" || price === ""){
document.getElementById("result").innerHTML = "Введите данные";
return;
}

let total = area * price;

document.getElementById("result").innerHTML =
"Стоимость объекта: <br>" + total + " ₽";

}

</script>

</body>
</html>
